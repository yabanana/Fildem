<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
  "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node>
  <interface name="org.fildem.v1.Hud">
    <method name="RequestHud">
      <arg name="window_uid" type="s" direction="in"/>
    </method>
    <method name="Query">
      <arg name="window_uid" type="s" direction="in"/>
      <arg name="term" type="s" direction="in"/>
      <arg name="results" type="aa{sv}" direction="out"/>
    </method>
    <method name="Execute">
      <arg name="window_uid" type="s" direction="in"/>
      <arg name="entry_id" type="s" direction="in"/>
    </method>
    <signal name="HudRequested">
      <arg name="window_uid" type="s"/>
    </signal>
  </interface>
</node>
